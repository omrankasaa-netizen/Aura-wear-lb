# Aura backend environment — copy to .env for local dev, or set these in Railway → Variables.
# NEVER commit the real .env (it is git-ignored).

# Port the server listens on. Railway sets PORT automatically; leave unset there.
PORT=4000

# Path to the SQLite database file.
# On Railway: mount a persistent Volume (e.g. at /data) and set MINIYO_DB_PATH=/data/data.db
# so your products/orders survive redeploys. Locally you can leave this unset.
MINIYO_DB_PATH=/data/data.db

# Resend transactional email
RESEND_API_KEY=your_resend_api_key_here
# Sender must be on a domain VERIFIED in Resend.
MINIYO_EMAIL_FROM=Aura <management@your-verified-domain.com>

# ---------------------------------------------------------------------------
# Super admin bootstrap
# ---------------------------------------------------------------------------
# Password for the seeded super admin (admin@aura.store). In production the
# admin is NOT seeded when this is unset — no default password is ever used
# outside local development. Keep it secret; set it in Railway → Variables.
# (MINIYO_ADMIN_PASSWORD is accepted as a legacy fallback.)
AURA_ADMIN_PASSWORD=

# Comma-separated emails promoted to super_admin on every boot (promote-only,
# never demotes). The owner email is always promoted automatically in addition
# to anything listed here.
AURA_SUPER_ADMIN_EMAILS=

# Session-signing secret. REQUIRED in production — the server refuses to boot
# without it. Generate a long random string and set it in Railway → Variables.
MINIYO_JWT_SECRET=

# ---------------------------------------------------------------------------
# Image storage — Cloudflare R2 (optional)
# ---------------------------------------------------------------------------
# When ALL of the required R2 vars below are set, uploaded product images are
# compressed to WebP (via sharp) and stored in YOUR OWN R2 bucket. When they
# are NOT set, uploads fall back to local disk (<repo>/uploads served at
# /uploads) so local dev keeps working with zero config.
#
# Use AURA's own bucket + public domain here. Do NOT reuse another store's
# bucket or image host.
#
# Required for R2:
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name
# Public base URL that serves objects from the bucket (custom domain or the
# r2.dev URL). Example: https://images.aura-lb.shop
R2_PUBLIC_BASE_URL=https://image.aura-lb.shop
# Optional: override the S3 endpoint. Defaults to
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com when omitted.
# R2_ENDPOINT=

# ---------------------------------------------------------------------------
# Cloudflare image resizing (optional, frontend)
# ---------------------------------------------------------------------------
# Enable on-the-fly resizing via Cloudflare /cdn-cgi/image. Defaults to "true",
# but only ever rewrites URLs whose host is listed in VITE_CF_RESIZE_HOSTS, so
# it is a safe no-op until you point it at your own Cloudflare-fronted host(s).
# Set to "false" to disable entirely.
VITE_CF_IMAGE_RESIZE=true
VITE_CF_RESIZE_HOSTS=image.aura-lb.shop

# ---------------------------------------------------------------------------
# Meta (Facebook) tracking — Pixel + Conversions API + Catalog feed
# ---------------------------------------------------------------------------
# ALL optional. When unset, tracking silently no-ops and the site is unaffected.
# See docs/META_TRACKING.md for full setup + Commerce Manager steps.
#
# Public Pixel ID exposed to the browser (Vite inlines VITE_* at build time).
# Consent-gated: the pixel only fires after the shopper accepts the banner.
VITE_META_PIXEL_ID=
#
# Same Pixel/Dataset ID for the backend Conversions API (server-side Purchase).
AURA_META_PIXEL_ID=
#
# Conversions API access token — SECRET. Backend only, NEVER exposed to the
# browser and NEVER committed. Set in Railway → Variables.
AURA_META_CAPI_ACCESS_TOKEN=
#
# Optional: routes CAPI events to the "Test Events" tab in Events Manager.
AURA_META_TEST_EVENT_CODE=
#
# Optional: public site origin used for catalog-feed links + CAPI event URLs.
# Defaults to https://aura-lb.shop when unset.
AURA_PUBLIC_BASE_URL=https://aura-lb.shop

# ---------------------------------------------------------------------------
# TikTok tracking — Pixel + Events API + Catalog feed
# ---------------------------------------------------------------------------
# ALL optional. When unset, the TikTok pixel is never injected and the Events
# API silently no-ops — the site is unaffected. See docs/TIKTOK_TRACKING.md.
#
# Public Pixel ID exposed to the browser (Vite inlines VITE_* at build time).
# Shares the Meta consent banner: ttq only fires after the shopper accepts.
# From TikTok Ads Manager → Assets → Events → Web Events → your pixel.
VITE_TIKTOK_PIXEL_ID=
#
# Same Pixel ID for the backend Events API (server-side CompletePayment).
AURA_TIKTOK_PIXEL_ID=
#
# Events API access token — SECRET. Backend only, NEVER exposed to the browser
# and NEVER committed. Set in Railway → Variables. Generate it in TikTok Events
# Manager → your pixel → Settings → Events API → Generate Access Token.
AURA_TIKTOK_ACCESS_TOKEN=
#
# Optional: routes Events API events to the "Test Events" tab in Events Manager
# (copy the code from that tab). Remove it when done testing.
AURA_TIKTOK_TEST_EVENT_CODE=
#
# The catalog feed endpoint (/tiktok-feed.csv) needs no env vars — it always
# works. Feed URL: https://aura-lb.shop/tiktok-feed.csv
