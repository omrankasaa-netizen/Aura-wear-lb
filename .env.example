# Aura backend environment — copy to .env for local dev, or set these in Railway → Variables.
# NEVER commit the real .env (it is git-ignored).

# Port the server listens on. Railway sets PORT automatically; leave unset there.
PORT=4000

# Path to the SQLite database file.
# On Railway: mount a persistent Volume (e.g. at /data) and set MINIYO_DB_PATH=/data/data.db
# so your products/orders survive redeploys. Locally you can leave this unset.
MINIYO_DB_PATH=/data/data.db

# Resend transactional email
RESEND_API_KEY=your_resend_api_key_here
# Sender must be on a domain VERIFIED in Resend.
MINIYO_EMAIL_FROM=Aura <management@your-verified-domain.com>

# ---------------------------------------------------------------------------
# Super admin bootstrap
# ---------------------------------------------------------------------------
# Comma-separated emails promoted to super_admin on every boot (promote-only,
# never demotes). The owner email is always promoted automatically in addition
# to anything listed here.
AURA_SUPER_ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Image storage — Cloudflare R2 (optional)
# ---------------------------------------------------------------------------
# When ALL of the required R2 vars below are set, uploaded product images are
# compressed to WebP (via sharp) and stored in YOUR OWN R2 bucket. When they
# are NOT set, uploads fall back to local disk (<repo>/uploads served at
# /uploads) so local dev keeps working with zero config.
#
# Use AURA's own bucket + public domain here. Do NOT reuse another store's
# bucket or image host.
#
# Required for R2:
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name
# Public base URL that serves objects from the bucket (custom domain or the
# r2.dev URL). Example: https://images.aura-lb.shop
R2_PUBLIC_BASE_URL=https://images.your-domain.com
# Optional: override the S3 endpoint. Defaults to
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com when omitted.
# R2_ENDPOINT=

# ---------------------------------------------------------------------------
# Cloudflare image resizing (optional, frontend)
# ---------------------------------------------------------------------------
# Enable on-the-fly resizing via Cloudflare /cdn-cgi/image. Defaults to "true",
# but only ever rewrites URLs whose host is listed in VITE_CF_RESIZE_HOSTS, so
# it is a safe no-op until you point it at your own Cloudflare-fronted host(s).
# Set to "false" to disable entirely.
VITE_CF_IMAGE_RESIZE=true
VITE_CF_RESIZE_HOSTS=images.your-domain.com
